# Build
build/
build-*/
.cache/
cmake-build-*/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Compiled
*.o
*.obj
*.a
*.so
*.dylib
*.js.map
# WASM build output (except demo/site copies)
build*/*.wasm

# Test data
*.yuv
*.265
*.h265
*.hevc
# Allow committed test fixtures
!tests/conformance/fixtures/*.265

# Conformance bitstreams (generated/downloaded, not committed)
tests/conformance/edge-cases/
tests/conformance/downloaded/

# Demo (generated by build scripts — sourcemaps only)
demo/worker.js
demo/*.js.map

# Site (sourcemaps only)
site/wasm/*.map

# Playwright
test-results/
playwright-report/

# Node.js / pnpm
node_modules/
packages/*/dist/
pnpm-debug.log*
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db

# Local logs
*.log
*.err
!CHANGELOG.md

# Python
__pycache__/
*.pyc
.venv/

# Internal dev files (not for public repo)
CLAUDE.md
MEMENTO-DEV.md
LEARNINGS.md
MASTER-PLAN.md
BACKLOG.md

# Secrets / credentials
*.env
*.env.*
*.pem
*.key

# Coverage
coverage/

# Spec PDF (copyright ITU-T, usage local uniquement)
docs/spec/pdf/
