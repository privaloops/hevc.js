{
  "name": "hevc.js",
  "version": "1.0.0",
  "private": true,
  "description": "HEVC/H.265 decoder in WebAssembly — 1080p@60fps, 236KB, zero dependencies",
  "type": "module",
  "exports": {
    ".": {
      "import": "./packages/core/dist/index.js",
      "types": "./packages/core/dist/index.d.ts"
    },
    "./dashjs-plugin": {
      "import": "./packages/dashjs-plugin/dist/index.js",
      "types": "./packages/dashjs-plugin/dist/index.d.ts"
    },
    "./wasm": "./packages/core/dist/wasm/hevc-decode.wasm"
  },
  "files": [
    "packages/core/dist/",
    "packages/dashjs-plugin/dist/"
  ],
  "scripts": {
    "build:wasm": "emcmake cmake -B build-wasm -DBUILD_WASM=ON -DCMAKE_BUILD_TYPE=Release && cmake --build build-wasm && cp build-wasm/hevc-decode.js build-wasm/hevc-decode.wasm packages/core/dist/wasm/",
    "build:core": "pnpm --filter @hevcjs/core build",
    "build:dashjs": "pnpm --filter @hevcjs/dashjs-plugin build",
    "build:demo:dash-bundle": "npx esbuild demo/dash-entry.ts --bundle --format=iife --global-name=HevcDash --outfile=demo/dash-bundle.js --external:dashjs --sourcemap --target=es2020",
    "build:demo:worker": "npx esbuild packages/core/src/transcode-worker.ts --bundle --format=iife --outfile=demo/transcode-worker.js --sourcemap --target=es2020",
    "build:demo:wasm": "cp build-wasm/hevc-decode.js build-wasm/hevc-decode.wasm demo/",
    "build:demo": "pnpm build:demo:dash-bundle && pnpm build:demo:worker && pnpm build:demo:wasm",
    "build:js": "pnpm -r build",
    "build": "pnpm build:wasm && pnpm build:js",
    "dev": "pnpm -r --parallel dev",
    "test": "cd build && ctest --output-on-failure",
    "test:native": "cmake -B build -DCMAKE_BUILD_TYPE=Debug && cmake --build build && cd build && ctest --output-on-failure",
    "test:e2e": "npx playwright test --project=local-chromium",
    "test:e2e:bs": "npx playwright test --project=bs-chrome-windows --project=bs-edge-windows --project=bs-firefox-windows --project=bs-chrome-macos --project=bs-safari-macos",
    "clean": "rm -rf build build-wasm packages/*/dist"
  },
  "keywords": [
    "hevc",
    "h265",
    "h264",
    "decoder",
    "transcoding",
    "webassembly",
    "wasm",
    "video",
    "codec",
    "browser",
    "mse",
    "media-source",
    "streaming",
    "dash",
    "dashjs"
  ],
  "license": "MIT",
  "author": "Thibaut Lion",
  "homepage": "https://hevcjs.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/privaloops/hevc.js.git"
  },
  "bugs": {
    "url": "https://github.com/privaloops/hevc.js/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "browserstack-local": "^1.5.13",
    "browserstack-node-sdk": "^1.52.3",
    "esbuild": "^0.28.0"
  }
}
