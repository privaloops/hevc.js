{
  "name": "@hevcjs/core",
  "version": "1.0.3",
  "description": "HEVC/H.265 video decoder for the browser using WebAssembly — decode HEVC streams directly in JavaScript with MSE support",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "wasm/",
    "README.md"
  ],
  "keywords": [
    "hevc",
    "h265",
    "h.265",
    "webassembly",
    "wasm",
    "codec",
    "video",
    "decoder",
    "browser",
    "streaming",
    "transcoding",
    "mse",
    "mediasource",
    "ott",
    "mp4",
    "hev1",
    "media-source-extensions"
  ],
  "author": "privaloops",
  "license": "MIT",
  "homepage": "https://hevcjs.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/privaloops/hevc.js.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/privaloops/hevc.js/issues"
  },
  "scripts": {
    "build": "tsup && mv dist/transcode-worker.global.js dist/transcode-worker.js && mv dist/transcode-worker.global.js.map dist/transcode-worker.js.map && mkdir -p dist/wasm && cp wasm/hevc-decode.js wasm/hevc-decode.wasm dist/wasm/",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "mp4box": "^2.3.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
